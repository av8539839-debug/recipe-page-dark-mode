// script.js
const botao = document.getElementById('btn-feito');
const mensagem = document.getElementById('mensagem');

botao.addEventListener('click', function() {
    // Altera o texto da mensagem escondida
    mensagem.classList.remove('hidden');
    mensagem.classList.add('finalizado');
    
    // Desabilita o botão e muda o texto
    botao.textContent = "Concluído!";
    botao.style.backgroundColor = "#7f8c8d";
    botao.disabled = true;

    // Um pequeno alerta de celebração
    alert("Parabéns! Você mestre da cozinha! 👨‍🍳");
});
const hora = new Date().getHours();
if (hora < 12) {
  alert("bom dia");

} else if (hora < 18) {
  alert("boa tarde ");

} else {
  alert("boa noite ");
}

const toggleMode = document.getElementById('toggleMode');

toggleMode.addEventListener('change', () => {
    // Liga ou desliga a classe .dark-mode no body
    document.body.classList.toggle('dark-mode');



})